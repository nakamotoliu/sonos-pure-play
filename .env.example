# Required when your OpenClaw browser RPC is gateway-auth protected.
OPENCLAW_GATEWAY_TOKEN=replace-me

# Optional. Example only.
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Optional browser profile name used by `openclaw browser ...` commands only.
# This is NOT the OpenClaw CLI global --profile state directory selector.
# Defaults to: openclaw
OPENCLAW_BROWSER_PROFILE=openclaw

# Optional runner-side headless override for Sonos skill logic.
# Accepted: true/false, 1/0, yes/no, on/off
# Defaults to: read from ~/.openclaw/openclaw.json browser.profiles.<name>.headless,
# then browser.headless
# OPENCLAW_BROWSER_HEADLESS=false
